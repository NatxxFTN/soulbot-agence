# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables — JAMAIS commiter ces fichiers
.env
.env.local
.env.*.local
.env.production

# Runtime data
data/*.db
data/*.db-shm
data/*.db-wal
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
build/
.next/
out/

# Coverage
coverage/

# Temporary files
tmp/
temp/
*.tmp

# Keep docs/bug-reports directory but not its contents (except .gitkeep)
docs/bug-reports/*
!docs/bug-reports/.gitkeep

# Runtime files in .agents_tech
.agents_tech/*.log
.agents_tech/*.pid

# Singleton lock (runtime-only, ne jamais commiter)
.bot.lock

# Templates de serveur (contenu privé — ignoré sauf exemple)
data/templates/*.json
!data/templates/_example.json

# Cache IDs emojis custom (généré par ;setupemojis)
data/emojis-ids.json
.backup-rebranding-*/
