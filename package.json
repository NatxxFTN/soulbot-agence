{
  "name": "discord-manager",
  "version": "1.0.0",
  "description": "Discord Bot + Web Dashboard Manager",
  "main": "index.js",
  "scripts": {
    "start":      "node index.js",
    "bot":        "node bot/index.js",
    "shard":      "node bot/shard.js",
    "dashboard":  "node dashboard/server.js",
    "dev":        "node index.js",
    "dev:bot":    "nodemon bot/index.js --ext js --ignore data/ --ignore .agents_tech/",
    "test":       "node --test tests/"
  },
  "dependencies": {
    "better-sqlite3":  "^12.8.0",
    "chalk":           "^4.1.2",
    "cors":            "^2.8.5",
    "discord.js":      "^14.14.1",
    "dotenv":          "^16.3.1",
    "express":         "^4.18.2",
    "express-session": "^1.17.3",
    "ms":              "^2.1.3",
    "socket.io":       "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
