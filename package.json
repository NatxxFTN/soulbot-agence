{
  "name": "discord-manager",
  "version": "2.0.0",
  "description": "Discord Bot + Web Dashboard Manager",
  "main": "index.js",
  "scripts": {
    "prestart": "node scripts/kill-bot.js",
    "start": "node bot/index.js",
    "bot": "node bot/index.js",
    "shard": "node bot/shard.js",
    "dashboard": "node dashboard/server.js",
    "dev": "concurrently -n bot,dashboard -c cyan,yellow \"npm run dev:bot\" \"npm run dashboard\"",
    "predev:bot": "node scripts/kill-bot.js",
    "dev:bot": "nodemon --config nodemon.json bot/index.js",
    "dev:all": "concurrently -n bot,dashboard -c cyan,yellow \"npm run dev:bot\" \"npm run dashboard\"",
    "test": "node --test tests/",
    "restart": "node scripts/kill-bot.js && rm -f .bot.lock && npm run dev",
    "restart:win": "scripts\\safe-restart.bat",
    "start:bot": "bash scripts/start-soulbot.sh",
    "start:bot:win": "scripts\\start-soulbot.bat",
    "emojis:check": "node bot/scripts/check-emoji-setup.js",
    "emojis:upload": "node bot/scripts/upload-emojis.js",
    "start:full": "bash scripts/start-all.sh",
    "start:full:win": "scripts\\start-all.bat",
    "security:secrets": "bash bot/scripts/check-secrets.sh"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.99",
    "better-sqlite3": "^12.8.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "ms": "^2.1.3",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
