# ================================
# DISCORD BOT CONFIGURATION
# ================================

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your bot's Client ID (Application ID)
CLIENT_ID=your_client_id_here

# Bot prefix for message commands
PREFIX=;

# IDs Discord des propriétaires du bot (séparés par virgule, Snowflakes 17-19 chiffres)
BOT_OWNERS=TON_ID_DISCORD_ICI

# ================================
# DASHBOARD CONFIGURATION
# ================================

# Secret for session encryption (change this!)
SESSION_SECRET=change_this_to_a_random_secret_string

# Dashboard port
PORT=3000

# Dashboard admin password (to access the dashboard)
DASHBOARD_PASSWORD=admin123
