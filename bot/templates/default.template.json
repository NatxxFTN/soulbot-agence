  "logs": {
    "enabled": true,
    "inherit_soulbot": true,
    "category_name": "-·{{STATS}}·- Logs",
    "position": 10,
    "channels": [
      {
        "name": "{{LOG_JOIN}} · arrives-departs",
        "events": ["guildMemberAdd", "guildMemberRemove"],
        "topic": "Mouvements des membres"
      },
      {
        "name": "{{LOG_EDIT}} · messages",
        "events": ["messageUpdate", "messageDelete", "messageDeleteBulk"],
        "topic": "Activite des messages"
      },
      {
        "name": "{{LOG_MOD}} · moderation",
        "events": ["guildBanAdd", "guildBanRemove"],
        "topic": "Actions de moderation"
      },
      {
        "name": "{{LOG_SETTINGS}} · serveur",
        "events": ["channelCreate", "channelDelete", "roleCreate", "roleDelete", "emojiCreate", "emojiDelete"],
        "topic": "Modifications du serveur"
      },
      {
        "name": "{{LOG_VOICE}} · vocal",
        "events": ["voiceStateUpdate"],
        "topic": "Activite vocale"
      }
    ]
  },

  "welcome": {
    "enabled": true,
    "title": "Bienvenue sur **{server}** !",
    "description": "Content(e) de t'avoir parmi nous.\nLis le reglement et profite du serveur !\n\nN'hesite pas a te presenter dans {welcome_channel}",
    "color": "#8B5CF6",
    "thumbnail": true,
    "image": null,
    "footer": "Serveur genere par Soulbot x ServerForge"
  },

  "rules": {
    "enabled": true,
    "title": "Reglement de {server}",
    "description": null,
    "rules": [
      "Respecte tous les membres sans exception — zero tolerance pour le harcelement",
      "Pas de spam, flood, ou publicite non autorisee en dehors des salons prevus",
      "Contenu NSFW strictement interdit — sanction immediate",
      "Respecte les directives officielles de Discord (Conditions d'Utilisation)",
      "Ecoute et respecte les decisions du staff en toutes circonstances",
      "Utilise les salons appropries pour chaque type de discussion"
    ],
    "color": "#8B5CF6",
    "footer": "En restant sur ce serveur, tu acceptes ces regles automatiquement"
  }
}
